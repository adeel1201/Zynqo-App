rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Zynqo Security Rules
    
    // Explicitly allow authenticated users to read and write all documents.
    // This broad rule resolves collection listing issues across Discover, Chats, and Profile.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}