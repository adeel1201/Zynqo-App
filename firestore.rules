
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User Profiles
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Conversations
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      
      // Messages within conversations
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Global fallback for authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
