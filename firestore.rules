rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Zynqo Security Rules
    
    // Allow users to read and update their own profile, and allow others to find them
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Allow authenticated users to manage chats they are part of
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      
      // Allow authenticated users to manage messages within their chats
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    // Default fallback for any other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}